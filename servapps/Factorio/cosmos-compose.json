{
    "cosmos-installer": {},
    "{ServiceName}-factorio": {
      "factorio-factorio": {
        "container_name": "{ServiceName}-factorio",
        "image": "factoriotools/factorio:stable",
        "restart": "unless-stopped",
        "ports": [
          "34197:34197/udp",
          "27015:27015/tcp"
        ],
        "labels": {
            "cosmos-force-network-secured": "true",
            "cosmos-auto-update": "true",
            "cosmos-icon": "https://jesserigon.github.io/cosmos-marketplace/servapps/Factorio/icon.png"
        },
        "volumes": [
          {
            "source": "/usr/data",
            "target": "/factorio",
            "type": "bind"
          }
        ],
        "environment": [
          "UPDATE_MODS_ON_START=true"
        ],
        "hostname": "{ServiceName}-factorio",
        "network_mode": "cosmos-{ServiceName}-factorio-default"
      }
    },
    "networks": {
      "cosmos-factorio-default": {}
    }
}